###############################################################################
# MediatR Playground API — Full HTTP Test Suite
#
# Run the API first: dotnet run --project src/MediatR.Playground.API
# Swagger UI: http://localhost:5005/swagger
#
# Visual Studio resolves {{MediatR_Playground_API_HostAddress}} automatically
# from launchSettings.json when the project is running.
###############################################################################

@MediatR_Playground_API_HostAddress = http://localhost:5005

###############################################################################
# REQUESTS & COMMANDS
###############################################################################

### Execute a SampleCommand — logging, validation, and authorization
POST {{MediatR_Playground_API_HostAddress}}/Requests/SampleCommand
Content-Type: application/json

{
  "description": "Test command from .http file"
}

### Execute a SampleRequest — logging only (no validation, no auth)
POST {{MediatR_Playground_API_HostAddress}}/Requests/SampleRequest
Content-Type: application/json

{
  "description": "Test request from .http file"
}

###############################################################################
# TRANSACTION REQUESTS
###############################################################################

### Get all sample entities (cached for 5s via CachingBehavior)
GET {{MediatR_Playground_API_HostAddress}}/TransactionRequests/SampleEntity

### Create a new sample entity (wrapped in a UoW transaction)
POST {{MediatR_Playground_API_HostAddress}}/TransactionRequests/AddSampleEntity
Content-Type: application/json

{
  "description": "Entity created via .http file"
}

### Get a sample entity by ID (replace GUID with actual Id from POST above)
GET {{MediatR_Playground_API_HostAddress}}/TransactionRequests/SampleEntity/c16d1c0d-b435-4bae-9a87-c357b9ffd97a

###############################################################################
# NOTIFICATIONS
###############################################################################

### Sequential — handlers run one after another in registration order
POST {{MediatR_Playground_API_HostAddress}}/Notifications/SequentialNotification

### Parallel — handlers run concurrently via Task.WhenAll
POST {{MediatR_Playground_API_HostAddress}}/Notifications/ParallelNotification

### Priority — handlers run in priority order (see IPriorityNotification)
POST {{MediatR_Playground_API_HostAddress}}/Notifications/SamplePriorityNotification

### Deduplication — handler registered twice, MediatR 14 ensures it runs only once
POST {{MediatR_Playground_API_HostAddress}}/Notifications/DeduplicationNotification

###############################################################################
# EXCEPTION HANDLING
###############################################################################

### InvalidOperationException — caught by specific handler, returns fallback response
POST {{MediatR_Playground_API_HostAddress}}/Exceptions/SampleCommandWithIOException
Content-Type: application/json

{
  "description": "Trigger InvalidOperationException"
}

### Generic Exception — caught by catch-all handler, returns fallback response
POST {{MediatR_Playground_API_HostAddress}}/Exceptions/SampleCommandWithException
Content-Type: application/json

{
  "description": "Trigger generic Exception"
}

### Not-found — no per-request handler, GlobalExceptionHandling only logs, returns 500
GET {{MediatR_Playground_API_HostAddress}}/Exceptions/NotFoundExceptionGlobalHandler

###############################################################################
# STREAM REQUESTS
###############################################################################

### Stream all sample entities (with generic logging pipeline)
GET {{MediatR_Playground_API_HostAddress}}/StreamRequests/SampleStreamEntity

### Stream with authorization filter pipeline
GET {{MediatR_Playground_API_HostAddress}}/StreamRequests/SampleStreamEntityWithPipeFilter
